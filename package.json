{
	"name": "pi-pkg-guard",
	"version": "0.11.0",
	"description": "Guards against unregistered pi packages — installed via npm but not registered in pi's settings",
	"type": "module",
	"license": "MIT",
	"author": "Alex Lee <657215+alexleekt@users.noreply.github.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/pi-pkg-guard"
	},
	"homepage": "https://github.com/earendil-works/pi-mono/tree/main/packages/pi-pkg-guard#readme",
	"bugs": {
		"url": "https://github.com/earendil-works/pi-mono/issues"
	},
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi-coding-agent",
		"package-manager",
		"guardrails",
		"npm",
		"extensions"
	],
	"files": [
		"extensions/",
		"test/",
		"justfile",
		"biome.json",
		"tsconfig.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "tsx --test test/**/*.test.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^20.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"pi": {
		"extensions": ["./extensions/index.ts"]
